# PricePilot — payment env vars
# Copy this file to .env locally; configure these in Vercel Project Settings → Environment Variables for production.

# ── Recipient wallet (where USDC payments land) ────────────────────────────
RECIPIENT_WALLET=0xYourBaseWalletHere

# Per-protocol overrides (optional — fall back to RECIPIENT_WALLET)
# X402_PAYEE_ADDRESS=
# MPP_RECIPIENT=

# ── x402 (Base) ────────────────────────────────────────────────────────────
# Testnet (Base Sepolia)
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator

# Mainnet (uncomment + flip to go live)
# X402_NETWORK=eip155:8453
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# ── MPP (Tempo) ────────────────────────────────────────────────────────────
# 64-char hex string — generate with: openssl rand -hex 32
MPP_SECRET_KEY=

# Tempo USDC token address (testnet vs mainnet — get from mpp.dev)
USDC_TEMPO=

# Set to "true" for testnet, leave unset / "false" for mainnet
MPP_TESTNET=true

# ── Optional ───────────────────────────────────────────────────────────────
# BASE_URL=https://pricepilot-sepia.vercel.app
