# ── LLM (OpenAI-compatible) ────────────────────────────────────────────────
OPENAI_API_KEY=
# Override to point at any OpenAI-compatible endpoint (Anthropic, local, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
# Model to use — e.g. gpt-4o, claude-3-5-sonnet-20241022, llama3, etc.
OPENAI_MODEL=gpt-4o

# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ── Nimble scraper ─────────────────────────────────────────────────────────
NIMBLE_API_KEY=
NIMBLE_BASE_URL=https://api.webit.live/api/v1/realtime/web

# ── ClickHouse ─────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
