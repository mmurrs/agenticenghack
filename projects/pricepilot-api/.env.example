# PricePilot API config.
# Copy to .env.mainnet for EigenCompute deploys or .env for local development.

SERVICE_NAME=pricepilot-search
SERVICE_VERSION=0.1.0
PORT=8080
BASE_URL=

# Route pricing, in USDC per successful paid request.
FIND_CHEAPEST_PRICE=0.03

# Nimble
NIMBLE_API_KEY=
NIMBLE_TIMEOUT_MS=90000
DEFAULT_ZIP_CODE=10001
MAX_OFFERS=8
NIMBLE_AMAZON_SEARCH_AGENT=amazon_serp
NIMBLE_AMAZON_PDP_AGENT=amazon_pdp
NIMBLE_WALMART_SEARCH_AGENT=walmart_serp
NIMBLE_WALMART_PDP_AGENT=walmart_pdp

# Shared recipient used as the default for both MPP_RECIPIENT and
# X402_PAYEE_ADDRESS. Generate a dedicated merchant wallet; do not reuse
# your AgentCash or personal wallet.
RECIPIENT_WALLET=

# MPP (Tempo USDC)
MPP_SECRET_KEY=
USDC_TEMPO=0x20C000000000000000000000b9537d11c60E8b50
MPP_RECIPIENT=
MPP_REALM=
MPP_TESTNET=false

# x402. For MPP-first demos, this can stay on Base Sepolia so CDP keys are not
# required. Switch to Base mainnet + CDP keys when you want x402 production.
X402_PAYEE_ADDRESS=
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
